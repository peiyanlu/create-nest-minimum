{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    "schedule:weekly",
    "group:allNonMajor"
  ],
  "labels": [
    "dependencies",
    "devDependencies"
  ],
  "ignorePaths": [
    "**/test/**"
  ],
  "rangeStrategy": "bump",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "timezone": "Asia/Shanghai",
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDepTypes": [
        "peerDependencies"
      ],
      "enabled": false
    },
    {
      "matchDepTypes": [
        "devDependencies",
        "dependencies"
      ],
      "groupName": "allDependencies",
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ],
  "ignoreDeps": [],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "src\/index\\.ts$"
      ],
      "matchStrings": [
        "\/\/\\s*renovate:\\s+datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+(?:var|let|const)\\s+\\S+\\s*=\\s*[\"'](?<currentValue>[^\"']+)[\"']"
      ]
    }
  ]
}
