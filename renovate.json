{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    "schedule:weekly",
    "group:allNonMajor"
  ],
  "automerge": true,
  "automergeType": "pr",
  "automergeStrategy": "rebase",
  "timezone": "Asia/Shanghai",
  "labels": ["dependencies"],
  "ignorePaths": [
    "**/test/**",
    "**/*-lock.yaml",
    "**/*-lock.json"
  ],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "labels": ["devDeps"]
    },
    {
      "matchDepTypes": ["peerDependencies"],
      "labels": ["peerDeps"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["major"],
      "labels": ["major"],
      "enabled": false
    }
  ],
  "ignoreDeps": ["node"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "src\/index\\.ts$"
      ],
      "matchStrings": [
        "\/\/\\s*renovate:\\s+datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+(?:var|let|const)\\s+\\S+\\s*=\\s*[\"'](?<currentValue>[^\"']+)[\"']"
      ]
    }
  ]
}
