{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    "config:recommended"
  ],
  "automergeType": "pr",
  "timezone": "Asia/Shanghai",
  "lockFileMaintenance": {
    "enabled": false,
    "schedule": [
      "before 5am on saturday"
    ]
  },
  "ignorePaths": [
    "**/test/**",
    "**/*-lock.yaml",
    "**/*-lock.json"
  ],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "packageRules": [
    {
      "matchDepTypes": [
        "dependencies",
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor",
        "bump"
      ],
      "groupName": "allDependencies",
      "automerge": true
    },
    {
      "matchPackagePatterns": [
        "^@types/"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor",
        "bump"
      ],
      "groupName": "DefinitelyTyped packages",
      "automerge": true
    },
    {
      "matchDepTypes": [
        "dependencies",
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "allDependencies only major",
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "src/index\\.ts$"
      ],
      "matchStrings": [
        "\/\/\\s*renovate:\\s+datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+(?:var|let|const)\\s+\\S+\\s*=\\s*[\"'](?<currentValue>[^\"']+)[\"']"
      ]
    }
  ]
}
