{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "generateOptions": {
    "spec": false
  },
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "static",
        "outDir": "dist",
        "watchAssets": true
      },
      {
        "include": "config/.env",
        "outDir": "dist",
        "watchAssets": true
      }
    ],
    "tsConfigPath": "./tsconfig.build.json"
  }
}
